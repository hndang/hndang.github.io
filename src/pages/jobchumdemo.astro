---
// Redirect to the live JobChum demo on GCP Cloud Run
const JOBCHUM_URL = "https://jobchum-507158723512.us-central1.run.app";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Waking JobChum… — Hoang Dang</title>
    <meta http-equiv="refresh" content={`4; url=${JOBCHUM_URL}`} />
    <meta name="description" content="Waking JobChum autonomous job application assistant demo. Please wait while we redirect you." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Special+Elite&family=IBM+Plex+Sans:wght@400;500&display=swap" rel="stylesheet" />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        background: #1c222c;
        color: #ece7da;
        font-family: 'IBM Plex Sans', system-ui, sans-serif;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
      }

      .container {
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
      }

      /* ── Robot face ────────────────────────────────────── */
      .robot {
        position: relative;
        width: 120px;
        height: 120px;
      }

      .robot-ring {
        position: absolute;
        inset: -12px;
        border-radius: 50%;
        border: 3px solid transparent;
        border-top-color: #dca148;
        animation: robot-spin 1.4s cubic-bezier(0.4, 0.0, 0.2, 1) infinite;
      }

      .robot-ring-2 {
        position: absolute;
        inset: -6px;
        border-radius: 50%;
        border: 2px solid transparent;
        border-bottom-color: #dca148;
        animation: robot-spin 1.8s cubic-bezier(0.4, 0.0, 0.2, 1) infinite reverse;
      }

      .robot-face {
        position: absolute;
        inset: 0;
        border-radius: 50%;
        background: #242c38;
        border: 2px solid #3a4456;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 18px;
      }

      .robot-eye {
        width: 14px;
        height: 18px;
        border-radius: 50%;
        background: #dca148;
        animation: robot-blink 2.4s ease-in-out infinite;
        box-shadow: 0 0 12px rgba(220, 161, 72, 0.4);
      }

      .robot-eye.left { animation-delay: 0s; }
      .robot-eye.right { animation-delay: 0.05s; }

      /* ── Title ──────────────────────────────────────────── */
      .title {
        font-family: 'Special Elite', 'Courier New', monospace;
        font-size: 2.8rem;
        color: #dca148;
        letter-spacing: 0.08em;
        line-height: 1.2;
      }

      .dots {
        display: inline-flex;
        gap: 2px;
      }

      .dots span {
        display: inline-block;
        animation: dot-bounce 1.2s ease-in-out infinite;
        opacity: 0.3;
      }

      .dots span:nth-child(1) { animation-delay: 0s; }
      .dots span:nth-child(2) { animation-delay: 0.2s; }
      .dots span:nth-child(3) { animation-delay: 0.4s; }

      /* ── Subtitle ───────────────────────────────────────── */
      .subtitle {
        font-size: 1rem;
        font-weight: 400;
        color: #8d96a8;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        position: relative;
        display: inline-block;
        background: linear-gradient(
          90deg,
          #8d96a8 0%,
          #ece7da 50%,
          #8d96a8 100%
        );
        background-size: 200% 100%;
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: shimmer 2s ease-in-out infinite;
      }

      /* ── Keyframes ──────────────────────────────────────── */
      @keyframes robot-spin {
        0%   { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
      }

      @keyframes robot-blink {
        0%, 45%, 55%, 100% { transform: scaleY(1); }
        50% { transform: scaleY(0.1); }
      }

      @keyframes dot-bounce {
        0%, 80%, 100% { transform: translateY(0); opacity: 0.3; }
        40% { transform: translateY(-8px); opacity: 1; }
      }

      @keyframes shimmer {
        0%   { background-position: 200% 0; }
        100% { background-position: -200% 0; }
      }

      /* ── Responsive ─────────────────────────────────────── */
      @media (max-width: 640px) {
        .title { font-size: 2rem; }
        .robot { width: 96px; height: 96px; }
        .robot-ring { inset: -10px; }
        .robot-ring-2 { inset: -5px; }
        .robot-eye { width: 11px; height: 14px; gap: 14px; }
        .container { gap: 1.5rem; }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="robot">
        <div class="robot-ring"></div>
        <div class="robot-ring-2"></div>
        <div class="robot-face">
          <div class="robot-eye left"></div>
          <div class="robot-eye right"></div>
        </div>
      </div>

      <div>
        <div class="title">
          Waking JobChum
          <span class="dots">
            <span>.</span><span>.</span><span>.</span>
          </span>
        </div>
      </div>

      <div class="subtitle">Please wait</div>
    </div>

    <script define:vars={{ url: JOBCHUM_URL }}>
      // Delay redirect so the animation is visible
      setTimeout(() => { window.location.href = url; }, 3000);
    </script>
  </body>
</html>