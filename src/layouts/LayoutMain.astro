---
import Layout from "./Layout.astro";
import Sidebar from "../components/Sidebar.astro";
import Footer from "../components/Footer.astro";
interface Props {
    title: string;
    description?: string;
    ogImage?: string;
    canonical?: string;
}
const { title, description, ogImage, canonical } = Astro.props;
---

<Layout title={`${title}`} description={description} ogImage={ogImage} canonical={canonical}>
    <Sidebar slot="header"/>
    <slot/>
    <Footer/>
    <div class="h-[20vh]" />
</Layout>
